{
  "name": "conversaja",
  "version": "0.0.1",
  "description": "Sistema Web de chat em tempo real — monorepo (Angular + NestJS).",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build:shared": "npm run build --workspace @conversaja/shared",
    "build": "npm run build:shared && npm run build --workspace backend && npm run build --workspace frontend",
    "dev:backend": "npm run start:dev --workspace backend",
    "dev:frontend": "npm run start --workspace frontend",
    "lint": "npm run lint --workspace backend",
    "test": "npm run test --workspace backend",
    "test:cov": "npm run test:cov --workspace backend",
    "test:e2e": "npm run test:e2e --workspace backend",
    "test:frontend": "npm run test --workspace frontend -- --watch=false --browsers=ChromeHeadless",
    "format": "prettier --write \"apps/**/src/**/*.ts\" \"packages/**/src/**/*.ts\"",
    "postinstall": "npm run build:shared"
  },
  "devDependencies": {
    "prettier": "^3.4.2"
  }
}
