# Conexão do backend com o PostgreSQL.
# No Docker Compose este valor já é definido automaticamente (serviço "db").
# Para desenvolvimento local, suba um Postgres (ex.: `docker compose up db`) e,
# se necessário, exporte esta variável antes de `npm run dev:backend`.
DATABASE_URL=postgresql://conversaja:conversaja@localhost:5432/conversaja

# Porta do backend (opcional; padrão 3000).
PORT=3000
